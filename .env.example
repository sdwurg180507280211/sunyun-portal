NODE_ENV=production
PORT=8080
NEXT_PUBLIC_SITE_URL=https://your-domain.com
DATABASE_PATH=/app/data/sunyun.db
LEGACY_LEADS_PATH=/app/data/leads.jsonl
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=scrypt:replace-with-generated-value
SESSION_SECRET=replace-with-at-least-32-random-bytes
SESSION_TTL_SECONDS=28800
COOKIE_SECURE=1
TRUST_PROXY=1
SUNYUN_PORT=8080
SUNYUN_DATA_DIR=/opt/sunyun-portal/data
SUNYUN_RUN_UID=1000
SUNYUN_RUN_GID=1000
# 首次升级期间可保留旧口令，便于自动回滚到旧镜像。
SUNYUN_ADMIN_TOKEN=
