# 本文件应放在 nginx 的 http 上下文 include 目录中（如 sites-enabled）。
# 只有公开 POST /api/leads 使用限流键；后台 GET /api/leads 不会被该规则误伤。
map $request_method $sunyun_lead_limit_key {
    default "";
    POST $binary_remote_addr;
}

limit_req_zone $sunyun_lead_limit_key zone=sunyun_leads:10m rate=5r/m;

server {
    listen 80;
    server_name your-domain.com;

    client_max_body_size 1m;

    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;
    add_header X-Frame-Options DENY always;

    location = /api/leads {
        limit_req zone=sunyun_leads burst=5 nodelay;
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
