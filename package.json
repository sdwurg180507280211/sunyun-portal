{
  "name": "sunyun-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "北京榫合云科技有限公司门户、软件项目线索与管理后台",
  "scripts": {
    "dev": "next dev -p 4173",
    "build": "next build",
    "start": "next start -p 8080",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "check": "npm run typecheck && npm test && npm run build",
    "db:migrate": "tsx scripts/migrate-jsonl-to-sqlite.ts",
    "db:backup": "tsx scripts/backup-db.ts",
    "auth:hash": "tsx scripts/hash-admin-password.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@heroui/react": "3.2.2",
    "@heroui/styles": "3.2.2",
    "better-sqlite3": "12.11.1",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-variants": "3.2.2",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.19.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.6",
    "tailwindcss": "4.3.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
